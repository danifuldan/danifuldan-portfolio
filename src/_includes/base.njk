<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {{ site.author }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta property="og:title" content="{% if title %}{{ title }} — {{ site.author }}{% else %}{{ site.title }}{% endif %}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <nav class="nav">
      <a href="/" class="nav-name">{{ site.author }}</a>
      <div class="nav-links">
        <div class="nav-dropdown">
          <a href="/" class="nav-dropdown-trigger" {% if page.url == "/" or (page.url and "/work/" in page.url) %}aria-current="page"{% endif %}>
            Work
            <svg class="nav-dropdown-caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <ul class="nav-dropdown-menu" role="menu">
            <li><a href="/" role="menuitem">All projects</a></li>
            {%- for project in collections.work | sort(false, false, 'data.order') %}
            <li><a href="{{ project.url }}" role="menuitem" {% if page.url == project.url %}aria-current="page"{% endif %}>{{ project.data.title }}</a></li>
            {%- endfor %}
          </ul>
        </div>
        <a href="/about/" {% if page.url == "/about/" %}aria-current="page"{% endif %}>About</a>
        <a href="mailto:{{ site.email }}">Contact</a>
        {% if page.url == "/" or (page.url and "/work/" in page.url) %}
        <img src="/img/avatar.jpg" alt="" class="nav-avatar">
        {% endif %}
      </div>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-links">
      <a href="https://github.com/danifuldan" target="_blank" rel="noopener">GitHub</a>
      <a href="https://danifuldan.substack.com" target="_blank" rel="noopener">Substack</a>
      <a href="https://twitter.com/danifuldan" target="_blank" rel="noopener">Twitter</a>
    </div>
  </footer>
</body>
</html>
